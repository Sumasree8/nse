# ══════════════════════════════════════════════════════════════════
# NSE — News-to-Startup Engine
# Environment Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────────
# Local MongoDB (default, no auth required in dev)
MONGODB_URI=mongodb://localhost:27017/nse

# Production MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nse?retryWrites=true&w=majority

# ── Redis ────────────────────────────────────────────────────────
# Leave empty to use in-memory mock (development only)
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_256_bit_random_secret_in_production

# ── AI (OpenAI) ──────────────────────────────────────────────────
# Leave empty to use built-in mock data (great for demos!)
OPENAI_API_KEY=

# ── External Data Sources ─────────────────────────────────────────
# Optional: Real news ingestion (https://newsapi.org)
NEWS_API_KEY=

# Optional: Reddit API (https://www.reddit.com/dev/api/)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=/api

# ── Feature Flags ────────────────────────────────────────────────
ENABLE_INGESTION=true
LOG_LEVEL=info

# ── Docker Secrets (used by docker-compose only) ─────────────────
MONGO_PASSWORD=nse_secret_2025
REDIS_PASSWORD=nse_redis_2025
